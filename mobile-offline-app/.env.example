# Alinhamento com o app web (GAS), escopo do APK e opções WebView vs nativo: ver ALIGNMENT.md na raiz desta pasta.
#
# Base da API (auth e sessão derivam desta URL se não definires overrides abaixo).
EXPO_PUBLIC_API_BASE_URL=https://setup-hu-app.pages.dev

# Opcional: URLs completas. Se omitidas, o app usa EXPO_PUBLIC_API_BASE_URL + /api/auth e + /api/me.
# EXPO_PUBLIC_AUTH_API_URL=https://setup-hu-app.pages.dev/api/auth
# EXPO_PUBLIC_ME_API_URL=https://setup-hu-app.pages.dev/api/me

# URL completa do POST de checklists (ver src/services/apiClient.ts). Em desenvolvimento podes usar httpbin.
EXPO_PUBLIC_SYNC_API_URL=https://httpbin.org/post
